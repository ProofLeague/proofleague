# Server-only TxLINE adapter configuration. Never expose these as NEXT_PUBLIC_* values.
# The official devnet endpoints below are used automatically when both credentials are set.
TXLINE_API_URL=https://txline-dev.txodds.com/api/fixtures/snapshot
TXLINE_SESSION_JWT=
TXLINE_API_TOKEN=
TXLINE_SCORES_URL_TEMPLATE=https://txline-dev.txodds.com/api/scores/snapshot/{fixtureId}
TXLINE_REQUEST_TIMEOUT_MS=8000
